# Public frontend configuration
# Safe to expose in the browser.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-the-anon-key-from-`npm run supabase:status`
VITE_LLM_PROVIDER=openrouter

# Server-only Coach runtime configuration
# Required if you want hosted BYOK providers to persist encrypted keys.
# Copy SUPABASE_SERVICE_ROLE_KEY from `npm run supabase:status`.
# USER_SECRET_ENCRYPTION_KEY should be a long random string kept only on the server.
SUPABASE_SERVICE_ROLE_KEY=replace-with-the-service-role-key-from-`npm run supabase:status`
USER_SECRET_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Optional Coach provider defaults
# VITE_LLM_PROVIDER also supports: openai, anthropic, google, local
# Hosted providers use a user-supplied BYOK key entered in Settings and stored encrypted server-side.
# OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# APP_NAME=STRATOS
# APP_URL=http://localhost:8080

# Optional local-model runtime
# LOCAL_LLM_URL=http://127.0.0.1:11434/v1/chat/completions

# Public frontend configuration
# Safe to expose in the browser.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-the-anon-key-from-`npm run supabase:status`

# Optional: allow account creation outside `vite dev`.
# Dev mode already enables self-signup automatically.
# VITE_ENABLE_SELF_SIGNUP=true

# Optional Coach runtime configuration
# Only needed if you want the Coach screen to call a model.
# Never prefix secrets with `VITE_`.
# VITE_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=replace-me
# OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# APP_NAME=STRATOS
# APP_URL=http://localhost:8080

# Optional local-model runtime
# VITE_LLM_PROVIDER=local
# LOCAL_LLM_URL=http://127.0.0.1:11434/v1/chat/completions
